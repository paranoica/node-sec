# ── Python ──────────────────────────────────────────────────────────────────
# Vendored & curated from github/gitignore (Python.gitignore) — CC0-1.0.
# NOTE: lockfiles (uv.lock, poetry.lock, Pipfile.lock) are COMMITTED for apps — not ignored.

# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
wheels/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage / type caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml

# Jupyter
.ipynb_checkpoints/
