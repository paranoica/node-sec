# Copy to .env and adjust. Never commit a real .env (it is gitignored).
# Local dev credentials for docker-compose (T003).
POSTGRES_USER=nodesec
POSTGRES_PASSWORD=nodesec
POSTGRES_DB=nodesec
GRAFANA_PASSWORD=admin

# Host port overrides — set these if a port is already taken on your machine
# (e.g. a local Postgres on 5432 or Redis on 6379). Container ports are fixed.
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# REDPANDA_PORT=9092
# REDPANDA_ADMIN_PORT=9644
# REDPANDA_PROXY_PORT=8082
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
